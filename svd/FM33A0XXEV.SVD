                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name />
                  <description>直接输出Group2的输入信号，计数模式、捕捉模式有效。</description>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name />
                  <description>PWM输出</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name />
                  <description>输出信号不能配置为APBCLK的同频信号，实际得到的结果为正向输出高电平，反向输出低电平</description>
                  <value>0</value>
