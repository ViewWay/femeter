              <name>CNTHSEL</name>
              <description>CNTHSEL  field description</description>
              <bitRange>[5:4]</bitRange>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name />
                  <description>选择ET1的低位计数器的溢出信号，与低位计数器组成16位计数器</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name />
                  <description>选择ET1的低位计数器的溢出信号，与低位计数器组成16位计数器</description>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name />
                  <description>选择内部捕捉源信号</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name />
                  <description>选择内部计数源信号或外部DIR输入组合信号</description>
                  <value>2</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>DIREN</name>
              <description>DIREN  field description</description>
              <bitRange>[3:3]</bitRange>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name />
                  <description>外部输入的DIR信号有效，此时高低位计数器是否计数可由外部输入的DIR信号控制。</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name />
                  <description>外部输入的DIR信号无效，此时高低位计数器是否计数将由内部控制信号控制。</description>
                  <value>0</value>
                </enumeratedValue>
