                <enumeratedValue>
                  <name />
                  <description>模式0，单次模运算，可配置4Block/16Block</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name />
                  <description>模式1，单次点运算，固定16Block</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name />
