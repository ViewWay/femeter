  <description>ARM 32-bit Cortex SC000 Microcontroller based device</description>
  <cpu>
    <name>SC000</name>
    <version>r1p0</version>
    <endian>little</endian>
    <mpuPresent>false</mpuPresent>
    <fpuPresent>false</fpuPresent>
