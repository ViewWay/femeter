                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name />
                  <description>仅计数器上溢出或下溢出会产生update中断或DMA请求</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>UDIS</name>
              <description>UDIS  field description</description>
              <bitRange>[1:1]</bitRange>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name />
                  <description>使能update事件；以下事件发生时产生update事件</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name />
                  <description>禁止update事件，不更新shadow寄存器。当UG置位或从机控制器收到硬件reset时重新初始化计数器和预分频器。</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
